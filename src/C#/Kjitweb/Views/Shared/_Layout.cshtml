@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KjitWeb</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <nav class="navbar bg-dark mb-4">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <span class="navbar-brand text-white mb-0">@(Configuration["Branding:CompanyName"] ?? "Firma")</span>
            @{
                var logoPath = Configuration["Branding:LogoPath"];
                if (!string.IsNullOrEmpty(logoPath))
                {
                    <img src="@logoPath" alt="Logo" style="height: 40px; max-width: 200px;" />
                }
            }
        </div>
    </nav>
    <div class="container py-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
